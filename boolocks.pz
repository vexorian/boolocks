e = OpenAntiGlue:yellow  and Background
d = OpenAntiGlue:blue    and Background

V = WildCard:yellow and Cross:yellow and Background


Wall = Wall:lock or AntiWall:color
player = Player:direction:lock or AntiPlayer:direction:color
Pushable = Block:color:lock or AntiBlock:other_color:color or AntiWildCard:color or WildCard:lock or Glue:lock or AntiGlue:color
Sticky = Glue:lock or AntiGlue:color

Block:red     = Block:color:red
Block:yellow  = Block:color:yellow
Block:blue    = Block:color:blue
Block:no_lock = Block:color:no_lock

OpenBlock:red     = OpenBlock:color:red
OpenBlock:yellow  = OpenBlock:color:yellow
OpenBlock:blue    = OpenBlock:color:blue


AntiBlock:red     = AntiBlock:color:red
AntiBlock:yellow  = AntiBlock:color:yellow
AntiBlock:blue    = AntiBlock:color:blue

OpenAntiBlock:red    = OpenAntiBlock:color:red
OpenAntiBlock:yellow = OpenAntiBlock:color:yellow
OpenAntiBlock:blue   = OpenAntiBlock:color:blue


WildCard = WildCard:lock
AntiWildCard = AntiWildCard:color

(In an ideal world, I would just be able to do With:color = ...:color , but this is
not an ideal world)
(With:color = (Block:red or AntiBlock:red or WildCard or AntiWildCard) Wall)
With:red    = Block:red:lock    or AntiBlock:red:color    or WildCard or AntiWildCard 
With:blue   = Block:blue:lock   or AntiBlock:blue:color   or WildCard or AntiWildCard 
With:yellow = Block:yellow:lock or AntiBlock:yellow:color or WildCard or AntiWildCard 




(I hate this so much, I had a better set of rules at one point, but I wanted to clean them up, it led to PS:next
basically dying on me and getting all bugged and I was forced to type these things to 'fix' the problem)

ClosedB:no_lock =      Block:no_lock or     Player:direction:no_lock  or     Glue:no_lock  or     WildCard:no_lock  or     Wall:no_lock
Closed:red   =      Block:red  or     Player:direction:red or     Glue:red or     WildCard:red or     Wall:red
Closed:yellow   =      Block:yellow  or     Player:direction:yellow or     Glue:yellow or     WildCard:yellow or     Wall:yellow
Closed:blue   =      Block:blue  or     Player:direction:blue or     Glue:blue or     WildCard:blue or     Wall:blue

AntiClosed:red   =      AntiBlock:red  or     AntiPlayer:direction:red or     AntiGlue:red or     AntiWildCard:red or     AntiWall:red
AntiClosed:yellow   =      AntiBlock:yellow  or     AntiPlayer:direction:yellow or     AntiGlue:yellow or     AntiWildCard:yellow or     AntiWall:yellow
AntiClosed:blue   =      AntiBlock:blue  or     AntiPlayer:direction:blue or     AntiGlue:blue or     AntiWildCard:blue or     AntiWall:blue


(BUG HERE, comment next line and comment ount the following 3 lines to fix it)
(Open:color       = OpenBlock:color or OpenPlayer:color or OpenGlue:color or  OpenWildCard:color or OpenWall:color)


Open:red       = OpenBlock:red or OpenPlayer:red or OpenGlue:red or OpenWildCard:red or OpenWall:red
Open:yellow    = OpenBlock:yellow or OpenPlayer:yellow or OpenGlue:yellow or OpenWildCard:yellow or OpenWall:yellow
Open:blue      = OpenBlock:blue or OpenPlayer:blue or OpenGlue:blue or OpenWildCard:blue or OpenWall:blue

OpenAnti:red       = OpenAntiBlock:red or OpenAntiPlayer:red or OpenAntiGlue:red or OpenAntiWildCard:red or OpenAntiWall:red
OpenAnti:yellow    = OpenAntiBlock:yellow or OpenAntiPlayer:yellow or OpenAntiGlue:yellow or OpenAntiWildCard:yellow or OpenAntiWall:yellow
OpenAnti:blue      = OpenAntiBlock:blue or OpenAntiPlayer:blue or OpenAntiGlue:blue or OpenAntiWildCard:blue or OpenAntiWall:blue

Solid = Closed:red or Closed:yellow or Closed:blue or ClosedB:no_lock or AntiClosed:color

(I think making it uneven makes it sound better)
LockRate = LockTick:m0 or LockTick:m4 or LockTick:m8 or LockTick:m10 or LockTick:m12 or LockTick:m16

