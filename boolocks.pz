S = Player:right:blue     and Background

q = OpenAntiPlayer:red     and Background
r = OpenAntiPlayer:yellow  and Background
s = OpenAntiPlayer:blue    and Background


W = Wall:no_lock and Background
X = Wall:red     and Background
Y = Wall:blue    and Background
Z = Wall:yellow  and Background

x = OpenAntiWall:red    and Background
y = OpenAntiWall:blue   and Background
z = OpenAntiWall:yellow and Background

I = Block:red:no_lock and Background
J = Block:red:yellow  and Background
